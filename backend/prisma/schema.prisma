// ============================================================
// S10 BizSmartHub — Prisma Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Snapshot de KPIs sincronizados desde S10
model KpiSnapshot {
  id          Int      @id @default(autoincrement())
  companyId   String // CodEmpresa del S10
  companyName String
  kpiType     String // 'pl' | 'cxc' | 'cxp' | 'caja' | 'gav' | 'gastos_financieros'
  period      String // 'YYYY' o 'YYYY-MM'
  year        Int
  month       Int? // null = datos anuales consolidados
  data        Json // payload completo del KPI
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, kpiType, period])
  @@index([companyId, year])
  @@index([kpiType, year])
  @@index([companyId, kpiType]) // getSnapshot por empresa + tipo
  @@index([year, kpiType, companyId]) // queries de consolidado / scorecard
}

// Empresas configuradas
model Company {
  id           Int      @id @default(autoincrement())
  codEmpresa   String   @unique
  name         String
  claseIngreso String   @default("70") // '70' para INTEGRAL, '75' para CMO GROUP
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Log de sincronizaciones
model SyncLog {
  id            Int      @id @default(autoincrement())
  companyId     String
  kpiType       String
  status        String // 'success' | 'error'
  mode          String // 'push' | 'direct'
  rowsProcessed Int      @default(0)
  errorMessage  String?
  triggeredBy   String   @default("scheduler") // 'scheduler' | 'manual' | 'agent'
  createdAt     DateTime @default(now())

  @@index([companyId, createdAt])
}

// Datos manuales del Reporte Directorio (Ppto, HH, Backlog, Pipeline, Flags, Must Win)
// Una fila por empresa × año × trimestre; payload completo en JSON para evolución flexible.
model DirectorioData {
  id        Int      @id @default(autoincrement())
  companyId String
  year      Int
  quarter   String   // 'Q1' | 'Q2' | 'Q3' | 'Q4'
  data      Json     // ver shape en DirectorioData.types.ts
  updatedAt DateTime @updatedAt
  updatedBy String?
  createdAt DateTime @default(now())

  @@unique([companyId, year, quarter])
  @@index([companyId, year])
}

// Usuarios del dashboard
model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  passwordHash     String
  role             String    @default("viewer") // 'admin' | 'viewer'
  allowedCompanies String[] // [] = todas las empresas
  allowedTabs      String[] // [] = todos los tabs
  active           Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
