// ============================================================
// S10 BizSmartHub — Prisma Schema
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Snapshot de KPIs sincronizados desde S10
model KpiSnapshot {
  id          Int      @id @default(autoincrement())
  companyId   String // CodEmpresa del S10
  companyName String
  kpiType     String // 'pl' | 'cxc' | 'cxp' | 'caja' | 'gav' | 'gastos_financieros'
  period      String // 'YYYY' o 'YYYY-MM'
  year        Int
  month       Int? // null = datos anuales consolidados
  data        Json // payload completo del KPI
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, kpiType, period])
  @@index([companyId, year])
  @@index([kpiType, year])
  @@index([companyId, kpiType]) // getSnapshot por empresa + tipo
  @@index([year, kpiType, companyId]) // queries de consolidado / scorecard
}

// ============================================================
// EL MAYOR — espejo relacional de AsientoContable (S10)
// Columna vertebral de trazabilidad: toda cifra contable es
// derivable de aquí y todo asiento es navegable. Se reemplaza
// por (companyId, anio) en cada sync. Capas de documentos
// (vw_12...) y tesorería (OB_*) se enlazan por nroD / nroAsiento.
// ============================================================
model LedgerEntry {
  id          BigInt   @id @default(autoincrement())
  companyId   String // CodEmpresa
  nroAsiento  String // CodAsientoContable — número de asiento (partida doble)
  codUnico    String? // CodUnico — orden estable dentro del asiento
  nroD        String? // documento relacionado → enlace a capa de documentos
  fecha       DateTime // FechaAplicacionContable
  anio        Int
  mes         Int
  codCuenta   String // cuenta contable completa
  clase       String // LEFT(codCuenta,2) — 10,12,40,60,70...
  grupoCuenta String // LEFT(codCuenta,4)
  desCuenta   String
  glosa       String   @default("")
  codTercero  String?
  tercero     String   @default("")
  debito      Decimal  @default(0) @db.Decimal(18, 2)
  credito     Decimal  @default(0) @db.Decimal(18, 2)
  syncedAt    DateTime @default(now())

  @@index([companyId, anio, codCuenta]) // navegación cuenta + año + saldo
  @@index([companyId, anio, clase]) // árbol por clase
  @@index([companyId, nroAsiento]) // drill: partida doble completa de un asiento
  @@index([companyId, nroD]) // enlace a documentos (CxC/CxP)
  @@index([companyId, anio, mes]) // filtro por periodo
}

// Empresas configuradas
model Company {
  id           Int      @id @default(autoincrement())
  codEmpresa   String   @unique
  name         String
  claseIngreso String   @default("70") // '70' para INTEGRAL, '75' para CMO GROUP
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Log de sincronizaciones
model SyncLog {
  id            Int      @id @default(autoincrement())
  companyId     String
  kpiType       String
  status        String // 'success' | 'error'
  mode          String // 'push' | 'direct'
  rowsProcessed Int      @default(0)
  errorMessage  String?
  triggeredBy   String   @default("scheduler") // 'scheduler' | 'manual' | 'agent'
  createdAt     DateTime @default(now())

  @@index([companyId, createdAt])
}

// Datos manuales del Reporte Directorio (Ppto, HH, Backlog, Pipeline, Flags, Must Win)
// Una fila por empresa × año × trimestre; payload completo en JSON para evolución flexible.
model DirectorioData {
  id        Int      @id @default(autoincrement())
  companyId String
  year      Int
  quarter   String   // 'Q1' | 'Q2' | 'Q3' | 'Q4'
  data      Json     // ver shape en DirectorioData.types.ts
  updatedAt DateTime @updatedAt
  updatedBy String?
  createdAt DateTime @default(now())

  @@unique([companyId, year, quarter])
  @@index([companyId, year])
}

// Usuarios del dashboard
model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  username         String?   @unique
  passwordHash     String
  role             String    @default("viewer") // 'admin' | 'viewer'
  allowedCompanies String[] // [] = todas las empresas
  allowedTabs      String[] // [] = todos los tabs
  active           Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  passwordResetTokens PasswordResetToken[]
}

// Tokens OTP para recuperación de contraseña
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
