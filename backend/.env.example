# ============================================================
# S10 BizSmartHub — Backend Environment Variables
# Copy to .env and fill in values
# ============================================================

# App
NODE_ENV=production
PORT=3202

# JWT
JWT_SECRET=change_me_use_openssl_rand_hex_32
JWT_EXPIRATION=8h

# PostgreSQL (Docker service name)
DATABASE_URL=postgresql://postgres:s10biz2026@s10biz-db:5432/s10biz_db?schema=public

# S10 SQL Server — solo necesario en modo 'direct'
S10_HOST=192.168.1.XXX
S10_PORT=1433
S10_USER=sa
S10_PASSWORD=
S10_DATABASE=CMO

# Sync mode: 'push' (agente local envía datos) | 'direct' (VPS conecta a SQL Server)
S10_SYNC_MODE=push

# API key para el endpoint /sync/push (generar: openssl rand -hex 24)
SYNC_API_KEY=change_me_use_openssl_rand_hex_24

# CORS
CORS_ORIGINS=https://s10bizsmarthub.bizwareapps.com
