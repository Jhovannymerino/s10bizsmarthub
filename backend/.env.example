NODE_ENV=development
PORT=3202

# PostgreSQL (Docker: s10biz-db / local: localhost:5435)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5435/s10biz_db?schema=public

# S10 ERP SQL Server (solo en modo direct)
S10_HOST=192.168.1.XXX
S10_PORT=1433
S10_USER=sa
S10_PASSWORD=
S10_DATABASE=CMO
S10_SYNC_MODE=push

# Seguridad
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=8h
SYNC_API_KEY=change_me_in_production

# CORS (separar multiples origenes con coma)
CORS_ORIGINS=http://localhost:3100
