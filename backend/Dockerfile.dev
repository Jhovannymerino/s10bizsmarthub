# ============================================================
# S10 BizSmartHub — Backend Dockerfile (development)
# ============================================================

FROM node:20-alpine

RUN apk add --no-cache openssl

WORKDIR /usr/src/app

COPY package*.json ./
RUN npm install

COPY . .

RUN npx prisma generate

EXPOSE 3202

CMD ["npm", "run", "start:dev"]
